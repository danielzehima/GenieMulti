# ===== Supabase (stockage des leads) =====
# URL du projet Supabase
NEXT_PUBLIC_SUPABASE_URL=https://glhianmardrihogowcjt.supabase.co
# Clé publique (anon / publishable) — à copier depuis :
# Supabase Dashboard > Project Settings > API > Project API keys > anon public
SUPABASE_ANON_KEY=
# OU clé service_role (secrète, serveur uniquement) — contourne le RLS,
# évite d'avoir à créer une policy d'insertion. Prioritaire si renseignée.
SUPABASE_SERVICE_ROLE_KEY=

# ===== Webhook externe (optionnel) =====
# URL du webhook (n8n, Zapier, Make...) qui reçoit les leads et déclenche
# les relances automatiques (email + WhatsApp). Laisser vide si non utilisé.
LEADS_WEBHOOK_URL=
